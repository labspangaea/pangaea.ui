---
import "../styles/app.css";
interface Props {
  title?: string;
}
const { title = "Pangaea Design System" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='7' fill='%23203150'/%3E%3Ccircle cx='16' cy='16' r='6' fill='%233fa9f5'/%3E%3C/svg%3E"
    />
    <title>{title}</title>
    <script is:inline>
      // Pre-paint theme from localStorage (mirrors pangaea.id 'pg_theme').
      try {
        if (localStorage.getItem("pg_theme") === "dark") {
          document.documentElement.setAttribute("data-rv-theme", "dark");
        }
      } catch (e) {}
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
