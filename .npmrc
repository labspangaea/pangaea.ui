# GitHub Packages — the @labspangaea scope publishes to GitHub Packages.
# Local workspace installs resolve @labspangaea/* from the workspace (npm symlinks
# them), so `npm install` needs no auth. Publishing — and consuming the packages
# from OUTSIDE this workspace — needs a token with write:packages / read:packages:
# export NODE_AUTH_TOKEN=<your PAT> (locally) or set it in CI (GITHUB_TOKEN works).
@labspangaea:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
package-lock=true
